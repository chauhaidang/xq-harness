{
  "name": "@chauhaidang/xq-harness-test-harness-e2e-consumer",
  "version": "0.0.0",
  "private": true,
  "description": "Exercises @chauhaidang/xq-harness-test-harness like an external consumer (single harness dependency)",
  "scripts": {
    "build": "true",
    "test": "yarn test:bdd",
    "test:bdd": "./node_modules/.bin/bddgen -c playwright.config.ts && ./node_modules/.bin/playwright test -c playwright.config.ts",
    "report:show": "./node_modules/.bin/playwright show-report playwright-report",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf .features-gen test-results playwright-report"
  },
  "dependencies": {
    "@chauhaidang/xq-harness-test-harness": "file:../xq-test-harness"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chauhaidang/xq-harness.git",
    "directory": "modules/xq-harness-test-harness-e2e-consumer"
  },
  "license": "Apache-2.0"
}
