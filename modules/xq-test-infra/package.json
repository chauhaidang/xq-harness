{
  "name": "@chauhaidang/xq-harness-test-infra",
  "version": "0.1.1",
  "description": "A test infra cli used to spin up test environment",
  "bin": {
    "xq-infra": "./bin/xq-infra.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "start": "node ./bin/xq-infra.js",
    "test": "jest ./tests --reporters=default --runInBand --coverage --testPathIgnorePatterns=integration.test.js",
    "test:all": "jest ./tests --reporters=default --runInBand --coverage",
    "build": "find . -name '*.js' -not -path './node_modules/*' -print0 | xargs -0 node --check && yarn test",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chauhaidang/xq-harness.git",
    "directory": "modules/xq-harness-test-infra"
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli"
  ],
  "author": "chauhaidang",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/chauhaidang/xq-harness/issues"
  },
  "homepage": "https://github.com/chauhaidang/xq-harness#readme",
  "dependencies": {
    "@chauhaidang/xq-harness-common-kit": "portal:../xq-common-kit",
    "commander": "^11.0.0",
    "cross-spawn": "7.0.6",
    "fs-extra": "^11.1.1",
    "uuid": "^9.0.0",
    "which": "^2.0.2",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^8.50.0",
    "jest": "^30.1.1"
  }
}
